# =============================================================
# client-onboarding-tool — environment variable reference
# =============================================================
# This file lists every env var the application code reads, with
# placeholder/blank values only — NEVER commit real secrets here.
# Real values live in the project's Vercel Environment Variables.
#
# Secrets (anything ending in _TOKEN, _KEY, _SECRET, plus
# SHARED_INTEGRATION_BEARER_TOKEN) belong on the Production scope
# in Vercel.
#
# Grouped by integration. Each var has a one-line comment on what
# it's for. Generated from a process.env grep of the codebase under
# src/; doc-only references (RAPIDAPI_KEY, NEXT_PUBLIC_SITE_URL,
# PLAYWRIGHT_VERCEL_SHARE_TOKEN — mentioned only in audit docs and
# the playwright-harness-plan) are excluded.

# =============================================================
# Supabase (the onboarding tool's primary backing store)
# =============================================================
# Public URL of the Supabase project.
NEXT_PUBLIC_SUPABASE_URL=
# Public anon key — safe to ship to the browser. Used by the
# client-side Supabase JS (src/lib/supabase/client.ts) for any
# RLS-gated reads.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — server-only. Used by every server route that
# writes onboarding_sessions, clients, onboarding_audit_events, etc.
# Treat as the keys-to-the-kingdom secret; never expose to browser.
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================
# Admin auth (/admin gate + admin onboarding endpoints)
# =============================================================
# Plaintext password compared by /api/admin/auth POST.
ADMIN_PASSWORD=
# Long random string (>=32 chars), HMAC key for the admin session cookie.
ADMIN_SESSION_SECRET=

# =============================================================
# Cross-repo integration (workbook → onboarding)
# =============================================================
# Bearer that the workbook's Phase-3 cron sends when calling
# /api/admin/onboarding/create and other admin-bearer-gated routes.
# Must match the same-named var on the workbook repo. Rotate both
# in lockstep.
SHARED_INTEGRATION_BEARER_TOKEN=

# =============================================================
# PIN-cookie security (client onboarding session auth)
# =============================================================
# Long random string (>=32 chars). HMAC key for the signed PIN cookie
# that proves the client has entered the correct PIN. Rotating this
# logs every client out of any in-progress session.
PIN_COOKIE_SECRET=

# =============================================================
# Site intelligence — opt-in prefill feature (analyze on step 1)
# =============================================================
# Set to "true" to enable the analyze-on-step-1 flow. Unset/false
# hides the AnalyzePanel and skips prefill entirely.
ENABLE_SITE_INTELLIGENCE_PREFILL=

# At least one analyzer key must be set for site intelligence to
# return useful data. Each is independent; the analyzer runs all
# configured providers in parallel and merges results.

# Firecrawl — page extraction (content, contact_public, key_pages).
# Required for the usable-content predicate to pass on real sites.
FIRECRAWL_API_KEY=

# Google PageSpeed Insights — Core Web Vitals + performance signals.
PAGESPEED_API_KEY=

# Wappalyzer — tech-stack detection. Optional.
WAPPALYZER_API_KEY=

# BuiltWith — alternative tech-stack signal. Optional.
BUILTWITH_API_KEY=
